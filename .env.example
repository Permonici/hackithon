OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_CHAT_INPUT_PRICE_PER_1M=0.15
OPENAI_CHAT_OUTPUT_PRICE_PER_1M=0.60
OPENAI_EMBEDDING_PRICE_PER_1M=0.02
PRICING_CURRENCY=USD
PRICING_REFERENCE_URL=https://platform.openai.com/docs/pricing

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=xdent_transcripts

# Lokální cesta na hostitelském počítači, kterou Docker připojí do kontejneru.
LOCAL_DATA_DIR=C:/Users/medun/Desktop/hacktaton/hackathon-filtered-expanded
DATA_DIR=/data
LOGS_DIR=/app/logs
CHUNK_SIZE=950
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=6
STRICT_MIN_SCORE=0.35
LENIENT_MIN_SCORE=0.18
BROAD_MIN_SCORE=0.10

CORS_ORIGINS=http://localhost:5173,http://localhost:8080
VITE_API_URL=/api
