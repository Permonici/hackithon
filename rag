<!DOCTYPE html>
<html lang="cs">

<head>
  <meta charset="UTF-8">
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: var(--font-sans, system-ui);
      background: var(--color-background-tertiary, #f5f5f0);
      min-height: 100vh;
    }

    .layout {
      display: grid;
      grid-template-columns: 320px 1fr;
      gap: 0;
      min-height: 100vh;
    }

    .sidebar {
      background: var(--color-background-primary, #fff);
      border-right: 0.5px solid var(--color-border-tertiary, #e0e0d8);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .sidebar-header {
      padding: 16px;
      border-bottom: 0.5px solid var(--color-border-tertiary, #e0e0d8);
    }

    .sidebar-header h2 {
      font-size: 13px;
      font-weight: 500;
      color: var(--color-text-secondary, #666);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 4px;
    }

    .sidebar-header p {
      font-size: 12px;
      color: var(--color-text-tertiary, #999);
    }

    .kb-section {
      flex: 1;
      overflow-y: auto;
      padding: 12px;
    }

    .kb-section-title {
      font-size: 11px;
      font-weight: 500;
      color: var(--color-text-tertiary, #999);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin: 8px 0 6px;
    }

    .kb-entry {
      background: var(--color-background-secondary, #f8f8f4);
      border: 0.5px solid var(--color-border-tertiary, #e0e0d8);
      border-radius: var(--border-radius-md, 8px);
      padding: 10px 12px;
      margin-bottom: 8px;
      cursor: pointer;
      transition: border-color 0.15s;
    }

    .kb-entry:hover {
      border-color: var(--color-border-secondary, #ccc);
    }

    .kb-entry.highlight {
      border-color: #1D9E75;
      background: #E1F5EE;
    }

    .kb-entry-q {
      font-size: 12px;
      font-weight: 500;
      color: var(--color-text-primary, #111);
      margin-bottom: 3px;
      line-height: 1.4;
    }

    .kb-entry-a {
      font-size: 11px;
      color: var(--color-text-secondary, #666);
      line-height: 1.4;
    }

    .kb-score {
      font-size: 10px;
      color: #0F6E56;
      font-weight: 500;
      margin-top: 4px;
    }

    .add-entry {
      padding: 12px;
      border-top: 0.5px solid var(--color-border-tertiary, #e0e0d8);
    }

    .add-entry textarea {
      width: 100%;
      font-size: 12px;
      padding: 8px;
      border: 0.5px solid var(--color-border-secondary, #ccc);
      border-radius: var(--border-radius-md, 8px);
      resize: none;
      background: var(--color-background-primary, #fff);
      color: var(--color-text-primary, #111);
      font-family: inherit;
      margin-bottom: 6px;
    }

    .add-entry textarea:focus {
      outline: none;
      border-color: #1D9E75;
    }

    .btn-add {
      width: 100%;
      font-size: 12px;
      padding: 7px;
      border: 0.5px solid var(--color-border-secondary, #ccc);
      border-radius: var(--border-radius-md, 8px);
      background: transparent;
      color: var(--color-text-primary, #111);
      cursor: pointer;
    }

    .btn-add:hover {
      background: var(--color-background-secondary, #f8f8f4);
    }

    .main {
      display: flex;
      flex-direction: column;
    }

    .top-bar {
      background: var(--color-background-primary, #fff);
      border-bottom: 0.5px solid var(--color-border-tertiary, #e0e0d8);
      padding: 14px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .agent-info {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .agent-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: #E1F5EE;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      color: #0F6E56;
    }

    .agent-name {
      font-size: 14px;
      font-weight: 500;
      color: var(--color-text-primary, #111);
    }

    .agent-sub {
      font-size: 11px;
      color: var(--color-text-secondary, #666);
    }

    .status-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #1D9E75;
      display: inline-block;
      margin-right: 5px;
    }

    .stats-bar {
      display: flex;
      gap: 16px;
    }

    .stat {
      text-align: center;
    }

    .stat-val {
      font-size: 16px;
      font-weight: 500;
      color: var(--color-text-primary, #111);
    }

    .stat-lbl {
      font-size: 10px;
      color: var(--color-text-tertiary, #999);
    }

    .chat-area {
      flex: 1;
      overflow-y: auto;
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .msg {
      max-width: 72%;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .msg.user {
      align-self: flex-end;
      align-items: flex-end;
    }

    .msg.agent {
      align-self: flex-start;
      align-items: flex-start;
    }

    .bubble {
      padding: 11px 15px;
      border-radius: var(--border-radius-lg, 12px);
      font-size: 14px;
      line-height: 1.6;
      border: 0.5px solid var(--color-border-tertiary, #e0e0d8);
    }

    .bubble.user {
      background: #1D9E75;
      color: #fff;
      border-color: #1D9E75;
      border-bottom-right-radius: 4px;
    }

    .bubble.agent {
      background: var(--color-background-primary, #fff);
      color: var(--color-text-primary, #111);
      border-bottom-left-radius: 4px;
    }

    .meta {
      font-size: 11px;
      color: var(--color-text-tertiary, #999);
    }

    .rag-trace {
      background: var(--color-background-secondary, #f8f8f4);
      border: 0.5px solid var(--color-border-tertiary, #e0e0d8);
      border-radius: var(--border-radius-md, 8px);
      padding: 8px 12px;
      font-size: 11px;
      color: var(--color-text-secondary, #666);
      max-width: 72%;
      align-self: flex-start;
    }

    .rag-trace strong {
      color: #0F6E56;
    }

    .thinking {
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--color-text-tertiary, #999);
      font-size: 13px;
    }

    .dots span {
      display: inline-block;
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: currentColor;
      margin: 0 1px;
      animation: bounce 1.2s infinite;
    }

    .dots span:nth-child(2) {
      animation-delay: 0.2s;
    }

    .dots span:nth-child(3) {
      animation-delay: 0.4s;
    }

    @keyframes bounce {

      0%,
      60%,
      100% {
        transform: translateY(0)
      }

      30% {
        transform: translateY(-5px)
      }
    }

    .input-bar {
      background: var(--color-background-primary, #fff);
      border-top: 0.5px solid var(--color-border-tertiary, #e0e0d8);
      padding: 14px 20px;
      display: flex;
      gap: 10px;
      align-items: flex-end;
    }

    .input-bar textarea {
      flex: 1;
      font-size: 14px;
      padding: 10px 14px;
      border: 0.5px solid var(--color-border-secondary, #ccc);
      border-radius: var(--border-radius-lg, 12px);
      resize: none;
      min-height: 44px;
      max-height: 120px;
      background: var(--color-background-primary, #fff);
      color: var(--color-text-primary, #111);
      font-family: inherit;
      line-height: 1.5;
    }

    .input-bar textarea:focus {
      outline: none;
      border-color: #1D9E75;
    }

    .send-btn {
      width: 44px;
      height: 44px;
      border-radius: var(--border-radius-lg, 12px);
      background: #1D9E75;
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-size: 18px;
      flex-shrink: 0;
    }

    .send-btn:hover {
      background: #0F6E56;
    }

    .send-btn:disabled {
      background: var(--color-background-secondary, #f8f8f4);
      color: var(--color-text-tertiary, #999);
      cursor: not-allowed;
    }

    .json-panel {
      background: #1a1a1a;
      color: #a8ff78;
      font-family: var(--font-mono, monospace);
      font-size: 11px;
      padding: 14px;
      border-top: 0.5px solid #333;
      max-height: 180px;
      overflow-y: auto;
      line-height: 1.5;
      white-space: pre-wrap;
      word-break: break-all;
    }

    .json-panel .key {
      color: #79d4f5;
    }

    .json-panel .str {
      color: #a8ff78;
    }

    .json-panel .num {
      color: #ffd27a;
    }

    .tab-bar {
      display: flex;
      border-bottom: 0.5px solid var(--color-border-tertiary, #e0e0d8);
      background: var(--color-background-primary, #fff);
    }

    .tab {
      padding: 10px 16px;
      font-size: 12px;
      cursor: pointer;
      border-bottom: 2px solid transparent;
      color: var(--color-text-secondary, #666);
    }

    .tab.active {
      border-bottom-color: #1D9E75;
      color: #0F6E56;
      font-weight: 500;
    }
  </style>
</head>

<body>

  <div class="layout">
    <div class="sidebar">
      <div class="sidebar-header">
        <h2>Znalostní databáze</h2>
        <p id="kb-count">0 položek · vektorová DB</p>
      </div>
      <div class="kb-section" id="kb-list"></div>
      <div class="add-entry">
        <div class="kb-section-title">Přidat nový záznam</div>
        <textarea id="new-q" rows="2" placeholder="Dotaz zákazníka..."></textarea>
        <textarea id="new-a" rows="2" placeholder="Správná odpověď..."></textarea>
        <button class="btn-add" onclick="addKbEntry()">+ Přidat do databáze</button>
      </div>
    </div>

    <div class="main">
      <div class="top-bar">
        <div class="agent-info">
          <div class="agent-avatar">🤖</div>
          <div>
            <div class="agent-name"><span class="status-dot"></span>RAG Support Operator</div>
            <div class="agent-sub">Claude Sonnet · cosine similarity · aktivní</div>
          </div>
        </div>
        <div class="stats-bar">
          <div class="stat">
            <div class="stat-val" id="stat-q">0</div>
            <div class="stat-lbl">dotazů</div>
          </div>
          <div class="stat">
            <div class="stat-val" id="stat-avg">—</div>
            <div class="stat-lbl">avg shoda</div>
          </div>
          <div class="stat">
            <div class="stat-val" id="stat-kb">0</div>
            <div class="stat-lbl">v DB</div>
          </div>
        </div>
      </div>

      <div class="tab-bar">
        <div class="tab active" onclick="switchTab('chat', this)">Chat</div>
        <div class="tab" onclick="switchTab('json', this)">JSON log</div>
      </div>

      <div class="chat-area" id="chat-area">
        <div class="msg agent">
          <div class="bubble agent">Dobrý den! Jsem váš AI operátor zákaznické podpory. Jak vám mohu pomoci? 😊</div>
          <div class="meta">RAG Operator · právě teď</div>
        </div>
      </div>

      <div class="json-panel" id="json-panel" style="display:none;">
        <div style="color:#666; margin-bottom:8px;">// JSON log RAG pipeline</div>
        <div id="json-log">čekám na první dotaz...</div>
      </div>

      <div class="input-bar">
        <textarea id="user-input" rows="1" placeholder="Napište dotaz zákazníka..."
          onkeydown="handleKey(event)"></textarea>
        <button class="send-btn" id="send-btn" onclick="sendMessage()">➤</button>
      </div>
    </div>
  </div>

  <script>
    const KB_DEFAULT = [
      { q: "Jak mohu vrátit zboží?", a: "Zboží lze vrátit do 30 dní od zakoupení. Stačí vyplnit formulář na našem webu v sekci 'Vrácení zboží' a přiložit kopii dokladu o koupi. Zboží zašlete na naši adresu nebo přineste osobně na pobočku." },
      { q: "Jak dlouho trvá doručení?", a: "Standardní doručení trvá 2–3 pracovní dny. Expresní doručení je možné do druhého dne za příplatek 99 Kč. Objednávky podané do 14:00 jsou expedovány tentýž den." },
      { q: "Jak mohu sledovat svou objednávku?", a: "Po odeslání objednávky obdržíte e-mail s trackovacím číslem. Stav zásilky můžete sledovat na webu přepravce nebo přímo v sekci 'Moje objednávky' ve vašem účtu." },
      { q: "Přijímáte platbu kartou?", a: "Ano, přijímáme všechny hlavní platební karty (Visa, Mastercard, American Express), PayPal, Google Pay, Apple Pay a samozřejmě platbu na dobírku nebo bankovním převodem." },
      { q: "Jak změním heslo k účtu?", a: "Heslo změníte v Nastavení účtu → Bezpečnost → Změnit heslo. Pokud jste heslo zapomněli, klikněte na 'Zapomenuté heslo' na přihlašovací stránce a my vám pošleme odkaz pro reset." },
      { q: "Máte záruční podmínky?", a: "Na veškeré zboží poskytujeme zákonnou záruku 24 měsíců. Na elektroniku navíc nabízíme rozšířenou záruku 36 měsíců. V případě reklamace kontaktujte podporu nebo navštivte pobočku." },
      { q: "Jak kontaktovat zákaznickou podporu?", a: "Zákaznickou podporu dostihnete na tel. 800 123 456 (zdarma, Po–Pá 8–20), e-mailem na podpora@eshop.cz nebo přes live chat na webu. Průměrná doba odezvy je do 2 hodin." },
      { q: "Lze zboží vyměnit za jiný produkt?", a: "Ano, výměnu zboží za jiný produkt rádi zařídíme. Postup je stejný jako u vrácení – vyplňte formulář a uveďte, za co si přejete produkt vyměnit. Případný cenový rozdíl doplatíte nebo vrátíme." },
    ];

    let knowledgeBase = [];
    let embeddings = [];
    let queryCount = 0;
    let totalSimilarity = 0;
    let lastJson = null;
    let activeTab = 'chat';

    function switchTab(tab, el) {
      activeTab = tab;
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      el.classList.add('active');
      document.getElementById('chat-area').style.display = tab === 'chat' ? 'flex' : 'none';
      document.getElementById('json-panel').style.display = tab === 'json' ? 'block' : 'none';
    }

    function simpleEmbed(text) {
      const words = text.toLowerCase().replace(/[^\wáéíóúůýžšřčďťň\s]/g, '').split(/\s+/).filter(Boolean);
      const vocab = {};
      words.forEach(w => { vocab[w] = (vocab[w] || 0) + 1; });
      return vocab;
    }

    function cosineSimilarity(a, b) {
      const keys = new Set([...Object.keys(a), ...Object.keys(b)]);
      let dot = 0, na = 0, nb = 0;
      keys.forEach(k => {
        const av = a[k] || 0, bv = b[k] || 0;
        dot += av * bv; na += av * av; nb += bv * bv;
      });
      if (!na || !nb) return 0;
      return dot / (Math.sqrt(na) * Math.sqrt(nb));
    }

    function retrieveTop(query, k = 3) {
      const qEmb = simpleEmbed(query);
      return knowledgeBase.map((entry, i) => ({
        ...entry, idx: i,
        score: cosineSimilarity(qEmb, embeddings[i])
      })).sort((a, b) => b.score - a.score).slice(0, k);
    }

    function addKbEntry(q, a) {
      const question = q || document.getElementById('new-q').value.trim();
      const answer = a || document.getElementById('new-a').value.trim();
      if (!question || !answer) return;
      knowledgeBase.push({ q: question, a: answer });
      embeddings.push(simpleEmbed(question + ' ' + answer));
      renderKb();
      document.getElementById('new-q').value = '';
      document.getElementById('new-a').value = '';
    }

    function renderKb(highlights = []) {
      const list = document.getElementById('kb-list');
      list.innerHTML = '';
      document.getElementById('kb-count').textContent = `${knowledgeBase.length} položek · vektorová DB`;
      document.getElementById('stat-kb').textContent = knowledgeBase.length;
      knowledgeBase.forEach((entry, i) => {
        const h = highlights.find(h => h.idx === i);
        const div = document.createElement('div');
        div.className = 'kb-entry' + (h ? ' highlight' : '');
        div.innerHTML = `<div class="kb-entry-q">${entry.q}</div><div class="kb-entry-a">${entry.a.substring(0, 80)}…</div>${h ? `<div class="kb-score">↗ shoda: ${(h.score * 100).toFixed(1)}%</div>` : ''}`;
        list.appendChild(div);
      });
    }

    function formatJson(obj) {
      return JSON.stringify(obj, null, 2)
        .replace(/"([^"]+)":/g, '<span class="key">"$1"</span>:')
        .replace(/: "([^"]*)"/g, ': <span class="str">"$1"</span>')
        .replace(/: (\d+\.?\d*)/g, ': <span class="num">$1</span>');
    }

    function appendMessage(role, content, meta = '') {
      const area = document.getElementById('chat-area');
      const div = document.createElement('div');
      div.className = `msg ${role}`;
      div.innerHTML = `<div class="bubble ${role}">${content}</div>${meta ? `<div class="meta">${meta}</div>` : ''}`;
      area.appendChild(div);
      area.scrollTop = area.scrollHeight;
      return div;
    }

    function appendTrace(hits) {
      const area = document.getElementById('chat-area');
      const div = document.createElement('div');
      div.className = 'rag-trace';
      div.innerHTML = `<strong>RAG retrieval</strong> — nalezeno ${hits.length} záznamů: ${hits.map(h => `"${h.q.substring(0, 30)}…" (${(h.score * 100).toFixed(1)}%)`).join(', ')}`;
      area.appendChild(div);
      area.scrollTop = area.scrollHeight;
    }

    function showThinking() {
      const area = document.getElementById('chat-area');
      const div = document.createElement('div');
      div.className = 'msg agent';
      div.id = 'thinking-bubble';
      div.innerHTML = `<div class="bubble agent"><div class="thinking">Přemýšlím <div class="dots"><span></span><span></span><span></span></div></div></div>`;
      area.appendChild(div);
      area.scrollTop = area.scrollHeight;
    }

    function removeThinking() {
      const t = document.getElementById('thinking-bubble');
      if (t) t.remove();
    }

    async function callClaude(question, context) {
      const systemPrompt = `Jsi přátelský a profesionální AI operátor zákaznické podpory. Odpovídáš POUZE na základě poskytnutého kontextu z databáze znalostí. Pokud kontext neobsahuje dostatečné informace, přiznej to a navrhni kontaktovat podporu přímo. Odpovídej v češtině, stručně a věcně.`;

      const userMsg = `Kontext z znalostní databáze:\n${context}\n\n---\nDotaz zákazníka: ${question}`;

      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 1000,
          system: systemPrompt,
          messages: [{ role: "user", content: userMsg }]
        })
      });
      const data = await res.json();
      return data.content?.[0]?.text || "Omlouvám se, nastala chyba.";
    }

    async function sendMessage() {
      const input = document.getElementById('user-input');
      const question = input.value.trim();
      if (!question) return;

      input.value = '';
      document.getElementById('send-btn').disabled = true;

      appendMessage('user', question, 'Zákazník · právě teď');

      const hits = retrieveTop(question, 3);

      appendTrace(hits);
      renderKb(hits);

      const context = hits.map((h, i) => `[${i + 1}] Q: ${h.q}\nA: ${h.a}`).join('\n\n');

      const ragJson = {
        pipeline: "RAG",
        query: question,
        retrieval: {
          top_k: 3,
          results: hits.map(h => ({
            question: h.q,
            answer: h.a.substring(0, 60) + "…",
            cosine_similarity: parseFloat((h.score).toFixed(4)),
            similarity_pct: parseFloat((h.score * 100).toFixed(1))
          }))
        },
        augmented_prompt: {
          system: "RAG Support Operator",
          context_length: context.length,
          model: "claude-sonnet-4-20250514"
        },
        timestamp: new Date().toISOString()
      };

      showThinking();

      let answer;
      try {
        answer = await callClaude(question, context);
      } catch (e) {
        answer = "Omlouvám se, nastala chyba při zpracování dotazu. Prosím kontaktujte podporu přímo.";
      }

      removeThinking();

      const topScore = hits[0]?.score || 0;
      queryCount++;
      totalSimilarity += topScore;
      document.getElementById('stat-q').textContent = queryCount;
      document.getElementById('stat-avg').textContent = (totalSimilarity / queryCount * 100).toFixed(0) + '%';

      ragJson.generation = {
        answer: answer.substring(0, 100) + (answer.length > 100 ? "…" : ""),
        top_similarity: parseFloat((topScore * 100).toFixed(1)),
        status: "ok"
      };
      lastJson = ragJson;

      document.getElementById('json-log').innerHTML = formatJson(ragJson);

      appendMessage('agent', answer.replace(/\n/g, '<br>'), `RAG Operator · shoda ${(topScore * 100).toFixed(0)}% · ${new Date().toLocaleTimeString('cs-CZ')}`);
      document.getElementById('send-btn').disabled = false;
    }

    function handleKey(e) {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
    }

    KB_DEFAULT.forEach(e => addKbEntry(e.q, e.a));
    renderKb();
  </script>
</body>

</html>
